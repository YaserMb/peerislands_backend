# Application
APP_NAME="Order Processing API"
ENVIRONMENT=local
DEBUG=true

# Database
# SQLite is the default local database so the API can run without external services.
DATABASE_URL=sqlite:///./app.db

# Security
# Replace this in real deployments. Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-local-env
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
