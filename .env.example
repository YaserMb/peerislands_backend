# Application
APP_NAME="Order Processing API"
ENVIRONMENT=local
DEBUG=true
LOG_LEVEL=INFO

# Database
# SQLite is the default local database so the API can run without external services.
DATABASE_URL=sqlite:///./app.db

# Background jobs
# Celery uses Redis as the local broker/result backend for scheduled processing.
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
PENDING_ORDER_PROCESSING_INTERVAL_SECONDS=300

# Security
# Replace this in real deployments. Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-local-env
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
